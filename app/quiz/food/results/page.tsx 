"use client";

import { useSearchParams } from "next/navigation";
import { useEffect, useState } from "react";

type RecipeResult = {
  id: string;
  name: string;
  poster_url?: string;
  description?: string;
  prep_time?: string;
  source?: string;
};

export default function FoodQuizResults() {
  const searchParams = useSearchParams();
  const sessionId = searchParams.get("s");

  const [results, setResults] = useState<RecipeResult[] | null>(null);
  const [loading, setLoading] = useState<boolean>(true);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    if (!sessionId) {
      setError("Missing session ID.");
      setLoading(false);
      return;
    }

    const fetchResults = async () => {
      try {
        const res = await fetch(`/v1/quiz/food/results?s=${sessionId}`);
        if (!res.ok) throw new Error("Failed to fetch recipes");
        const data = await res.json();
        setResults(data.results || []);
      } catch (err) {
        setError("Could not fetch results. Please try again.");
      } finally {
        setLoading(false);
      }
    };

    fetchResults();
  }, [sessionId]);

  if (loading) {
    return <div className="text-center mt-20 text-gray-500">Loading recipes…</div>;
  }

  if (error) {
    return <div className="text-center mt-20 text-red-600">{error}</div>;
  }

  return (
    <section className="max-w-5xl mx-auto px-4 py-10">
      <h1 className="text-2xl font-bold mb-6 text-center">🍽️ Your Recipe Picks</h1>
      <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {results?.map((recipe) => (
          <div
            key={recipe.id}
            className="rounded-lg overflow-hidden border bg-white shadow hover:shadow-lg transition"
          >
            {recipe.poster_url && (
              <img
                src={recipe.poster_url}
                alt={recipe.name}
                className="w-full h-60 object-cover"
              />
            )}
            <div className="p-4">
              <h3 className="text-lg font-semibold mb-1">{recipe.name}</h3>
              {recipe.description && (
                <p className="text-sm text-gray-600 line-clamp-3">{recipe.description}</p>
              )}
              {recipe.prep_time && (
                <p className="text-xs text-teal-700 mt-2">⏱️ {recipe.prep_time}</p>
              )}
              {recipe.source && (
                <p className="text-xs text-gray-400 italic mt-1">Source: {recipe.source}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  );
}

